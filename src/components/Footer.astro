---
import site from '../content/site.json';
import { withBase } from '../utils/paths';
---
<footer class="footer">
  <div class="container grid grid-3">
    <div><p class="eyebrow">Daniel & Colleen</p><h3>September 11, 2027</h3><p>{site.venue}<br />{site.location}</p></div>
    <div><p class="eyebrow">Questions</p><p>{site.contact}</p><p><a href={withBase('/faq')}>Read the FAQ</a></p></div>
    <div><p class="eyebrow">Location</p><p>{site.address}</p><p>Please plan transportation in advance.</p></div>
  </div>
</footer>
