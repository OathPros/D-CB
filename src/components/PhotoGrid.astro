---
type PhotoGridItem = {
  caption: string;
  alt: string;
};

interface Props {
  items: PhotoGridItem[];
}

const { items } = Astro.props;
---
<div class="photo-grid">{items.map((item) => <figure class="photo-card"><figcaption><strong>{item.caption}</strong><br /><span>{item.alt}</span></figcaption></figure>)}</div>
