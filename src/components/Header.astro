---
const nav = [ ['/', 'Home'], ['/schedule','Schedule'], ['/rsvp','RSVP'], ['/faq','FAQ'], ['/travel','Travel'], ['/venue','Venue'], ['/story','Story'], ['/party','Party'], ['/gifts','Gifts'], ['/ottawa','Ottawa'], ['/gallery','Gallery'] ];
const current = Astro.url.pathname.replace(/\/$/, '') || '/';
---
<header class="site-header">
  <nav class="nav container" aria-label="Primary navigation">
    <a class="brand" href="/">Daniel & Colleen</a>
    <button class="menu-toggle" aria-expanded="false" aria-controls="primary-menu">Menu</button>
    <div class="nav-links" id="primary-menu">
      {nav.map(([href,label]) => <a href={href} aria-current={(current === href || (href !== '/' && current === href)) ? 'page' : undefined}>{label}</a>)}
    </div>
  </nav>
</header>
<script>
  const toggle = document.querySelector('.menu-toggle');
  const links = document.querySelector('.nav-links');
  toggle?.addEventListener('click', () => {
    const open = !links?.classList.contains('open');
    links?.classList.toggle('open', open);
    document.body.classList.toggle('menu-open', open);
    toggle.setAttribute('aria-expanded', String(open));
  });
</script>
